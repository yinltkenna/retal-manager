    <Folder Include="DTOs\Requests\" />
    <Folder Include="DTOs\Responses\" />
    <Folder Include="Messaging\Consumers\" />
    <Folder Include="Messaging\EventContracts\" />
    <Folder Include="Messaging\Outbox\" />
    <Folder Include="Messaging\Publishers\" />
    <Folder Include="Middleware\" />
    <Folder Include="Repositories\Interfaces\" />
    <Folder Include="Services\Interfaces\" />
  </ItemGroup>

</Project>
